    exists Piece( type == Piece.Type.BISHOP, color == Piece.Color.BLACK )
    exists Piece( type == Piece.Type.PAWN,   color == Piece.Color.BLACK )
    not exists Piece( type != Piece.Type.KING, color == Piece.Color.WHITE )
    accumulate(
        Piece( type != Piece.Type.KING, type != Piece.Type.BISHOP, type != Piece.Type.PAWN, color == Piece.Color.BLACK );
        $other : count(1);
        $other == 0
    )
    not DerivedFact( type == "BISHOP_PAWN_VS_KING" )
then
    modify( $pos ) { setEndgameType( "BISHOP_PAWN_VS_KING" ) }
    insert( new DerivedFact(
        "BISHOP_PAWN_VS_KING", Piece.Color.BLACK,
        "Bishop and pawn(s) vs. lone king — check for wrong-color bishop draw.",
        1, "Silman, Part Four (Class C), p.112"
    ));
