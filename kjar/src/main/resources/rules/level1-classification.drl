package rules;

import com.github.nikola352.chess_endgame_analyzer.model.models.Piece;
import com.github.nikola352.chess_endgame_analyzer.model.models.Position;

// Rule 1 - Endgame Detection
rule "Endgame Detection"
when
    $pos : Position()
    not DerivedFact( type == "ENDGAME_DETECTED" )
    accumulate(
        Piece( type != Piece.Type.KING );
        $c : count(1);
        $c <= 6
    )
then
    insert( new DerivedFact(
        "ENDGAME_DETECTED", null,
        "Position has " + $c + " non-king piece(s) — endgame analysis rules apply.",
        1, "General knowledge"
    ));
end

// Rule 2 - King-Pawn Endgame Classification
rule "King-Pawn Endgame Classification"
when
    $pos : Position()
    DerivedFact( type == "ENDGAME_DETECTED" )
    accumulate(
        Piece( type != Piece.Type.KING, type != Piece.Type.PAWN );
        $np : count(1);
        $np == 0
    )
    exists Piece( type == Piece.Type.PAWN )
    not DerivedFact( type == "KING_PAWN_ENDGAME" )
then
    modify( $pos ) { setEndgameType( "KING_PAWN_ENDGAME" ) }
    insert( new DerivedFact(
        "KING_PAWN_ENDGAME", null,
        "Position contains only kings and pawns — king-pawn endgame theory applies.",
        1, "de la Villa, Chapter 1, p.27"
    ));
end

// Rule 3 - Rook+Pawn vs Rook Classification
rule "Rook-Pawn vs Rook Classification"
when
    $pos : Position()
    DerivedFact( type == "ENDGAME_DETECTED" )
    not DerivedFact( type == "KING_PAWN_ENDGAME" )
    accumulate(
        Piece( type == Piece.Type.PAWN );
        $pawns : count(1);
        $pawns == 1
    )
    exists Piece( type == Piece.Type.ROOK, color == Piece.Color.WHITE )
    exists Piece( type == Piece.Type.ROOK, color == Piece.Color.BLACK )
    accumulate(
        Piece( type != Piece.Type.KING, type != Piece.Type.ROOK, type != Piece.Type.PAWN );
        $other : count(1);
        $other == 0
    )
    $pawn : Piece( type == Piece.Type.PAWN, $pawnColor : color )
    not DerivedFact( type == "ROOK_PAWN_VS_ROOK" )
then
    modify( $pos ) { setEndgameType( "ROOK_PAWN_VS_ROOK" ) }
    insert( new DerivedFact(
        "ROOK_PAWN_VS_ROOK", $pawnColor,
        "Rook + pawn vs. rook — Lucena and Philidor theory applies. (de la Villa, Endings 52-53, p.124-125)",
        1, "de la Villa, Endings 52-53, p.124-125"
    ));
end

// Rule 4 - Pure Rook Endgame Classification
rule "Pure Rook Endgame Classification"
when
    $pos : Position()
    DerivedFact( type == "ENDGAME_DETECTED" )
    not DerivedFact( type == "KING_PAWN_ENDGAME" )
    exists Piece( type == Piece.Type.ROOK, color == Piece.Color.WHITE )
    exists Piece( type == Piece.Type.ROOK, color == Piece.Color.BLACK )
    not exists Piece( type == Piece.Type.PAWN )
    accumulate(
        Piece( type != Piece.Type.KING, type != Piece.Type.ROOK );
        $other : count(1);
        $other == 0
    )
    not DerivedFact( type == "PURE_ROOK_ENDGAME" )
then
    modify( $pos ) { setEndgameType( "PURE_ROOK_ENDGAME" ) }
    insert( new DerivedFact(
        "PURE_ROOK_ENDGAME", null,
        "Only kings and rooks remain — fortress and activity principles apply.",
        1, "de la Villa, Chapter 10 general"
    ));
end

// Rule 5 - Bishop+Pawn vs Lone King (White attacker)
rule "Bishop-Pawn vs Lone King Classification - White attacker"
salience 1
when
    $pos : Position()
    DerivedFact( type == "ENDGAME_DETECTED" )
    not DerivedFact( type == "KING_PAWN_ENDGAME" )
    exists Piece( type == Piece.Type.BISHOP, color == Piece.Color.WHITE )
    exists Piece( type == Piece.Type.PAWN,   color == Piece.Color.WHITE )
    not exists Piece( type != Piece.Type.KING, color == Piece.Color.BLACK )
    accumulate(
        Piece( type != Piece.Type.KING, type != Piece.Type.BISHOP, type != Piece.Type.PAWN, color == Piece.Color.WHITE );
        $other : count(1);
        $other == 0
    )
    not DerivedFact( type == "BISHOP_PAWN_VS_KING" )
then
    modify( $pos ) { setEndgameType( "BISHOP_PAWN_VS_KING" ) }
    insert( new DerivedFact(
        "BISHOP_PAWN_VS_KING", Piece.Color.WHITE,
        "Bishop and pawn(s) vs. lone king — check for wrong-color bishop draw.",
        1, "Silman, Part Four (Class C), p.112"
    ));
end

