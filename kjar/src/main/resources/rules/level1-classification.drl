// Rule 7 - Knight+Pawn vs Lone King (White attacker)
rule "Knight-Pawn vs Lone King Classification - White attacker"
salience 1
when
    $pos : Position()
    DerivedFact( type == "ENDGAME_DETECTED" )
    not DerivedFact( type == "KING_PAWN_ENDGAME" )
    exists Piece( type == Piece.Type.KNIGHT, color == Piece.Color.WHITE )
    exists Piece( type == Piece.Type.PAWN,   color == Piece.Color.WHITE )
    not exists Piece( type != Piece.Type.KING, color == Piece.Color.BLACK )
    accumulate(
        Piece( type != Piece.Type.KING, color == Piece.Color.WHITE );
        $wc : count(1);
        $wc == 2
    )
    not DerivedFact( type == "KNIGHT_PAWN_VS_KING" )
then
    modify( $pos ) { setEndgameType( "KNIGHT_PAWN_VS_KING" ) }
    insert( new DerivedFact(
        "KNIGHT_PAWN_VS_KING", Piece.Color.WHITE,
        "Knight + pawn vs. lone king — draw if defending king blockades or knight is wrong color.",
        1, "de la Villa, Chapter 3, p.51"
    ));
end

