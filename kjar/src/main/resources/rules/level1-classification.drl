// Rule 6 - Rook+Pawn vs Lone King (White attacker)
rule "Rook-Pawn vs Lone King Classification - White attacker"
salience 1
when
    $pos : Position()
    DerivedFact( type == "ENDGAME_DETECTED" )
    not DerivedFact( type == "KING_PAWN_ENDGAME" )
    exists Piece( type == Piece.Type.ROOK, color == Piece.Color.WHITE )
    exists Piece( type == Piece.Type.PAWN, color == Piece.Color.WHITE )
    not exists Piece( type != Piece.Type.KING, color == Piece.Color.BLACK )
    accumulate(
        Piece( type != Piece.Type.KING, color == Piece.Color.WHITE );
        $wc : count(1);
        $wc == 2
    )
    not DerivedFact( type == "ROOK_PAWN_VS_KING" )
then
    modify( $pos ) { setEndgameType( "ROOK_PAWN_VS_KING" ) }
    insert( new DerivedFact(
        "ROOK_PAWN_VS_KING", Piece.Color.WHITE,
        "Rook + pawn vs. lone king — winning unless corner defense draws.",
        1, "de la Villa, Chapters 5-10"
    ));
end

