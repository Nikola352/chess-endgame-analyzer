// Rule 15 - Key Square Occupied: fires when the attacking king stands on a dynamically
// derived key square (KeySquare facts inserted by the key-file-rules template at runtime).
rule "Key Square Occupied"
when
    DerivedFact( type == "KING_PAWN_ENDGAME" )
    KeySquare( $color : pawnColor, $pf : pawnFile, $sq : square )
    Piece( type == Piece.Type.KING, color == $color, square == $sq )
    not DerivedFact( type == "KEY_SQUARE_OCCUPIED", side == $color )
then
    insert( new DerivedFact(
        "KEY_SQUARE_OCCUPIED",
        $color,
        "Attacking king occupies key square " + $sq + " for the " + $pf + "-pawn — promotion guaranteed regardless of defender. (de la Villa, Ending 3, p.33)",
        1,
        "de la Villa, Ending 3, p.33"
    ));
end

// Rule 16 - Wrong Color Bishop (White attacker)
// Bishop does not control the promotion square of the rook pawn.
rule "Wrong Color Bishop - White attacker"
when
    DerivedFact( type == "BISHOP_PAWN_VS_KING", side == Piece.Color.WHITE )
    $p : Piece( type == Piece.Type.PAWN, color == Piece.Color.WHITE,
                square matches "[ah][1-8]",
                $pFile : square.substring(0,1) )
    $b : Piece( type == Piece.Type.BISHOP, color == Piece.Color.WHITE, $bSq : square )
    not DerivedFact( type == "WRONG_COLOR_BISHOP" )
then
    String promSq = $pFile + "8";
    int bColor  = ($b.getSquare().codePointAt(0) - 97 + $b.getSquare().codePointAt(1) - 49) % 2;
    int psColor = (promSq.codePointAt(0) - 97 + promSq.codePointAt(1) - 49) % 2;
    if ( bColor != psColor ) {
        insert( new DerivedFact(
            "WRONG_COLOR_BISHOP", Piece.Color.WHITE,
            "The bishop does not control the promotion square " + promSq + " — the defending king draws by reaching the promotion corner. (Silman, Part Four (Class C), p.112; de la Villa, Ending 4, p.37)",
            1, "Silman, Part Four (Class C), p.112; de la Villa, Ending 4, p.37"
        ));
    }
end

// Rule 16b - Wrong Color Bishop (Black attacker)
rule "Wrong Color Bishop - Black attacker"
when
    DerivedFact( type == "BISHOP_PAWN_VS_KING", side == Piece.Color.BLACK )
    $p : Piece( type == Piece.Type.PAWN, color == Piece.Color.BLACK,
                square matches "[ah][1-8]",
                $pFile : square.substring(0,1) )
    $b : Piece( type == Piece.Type.BISHOP, color == Piece.Color.BLACK, $bSq : square )
    not DerivedFact( type == "WRONG_COLOR_BISHOP" )
then
    String promSq = $pFile + "1";
    int bColor  = ($b.getSquare().codePointAt(0) - 97 + $b.getSquare().codePointAt(1) - 49) % 2;
    int psColor = (promSq.codePointAt(0) - 97 + promSq.codePointAt(1) - 49) % 2;
    if ( bColor != psColor ) {
        insert( new DerivedFact(
            "WRONG_COLOR_BISHOP", Piece.Color.BLACK,
            "The bishop does not control the promotion square " + promSq + " — the defending king draws by reaching the promotion corner. (Silman, Part Four (Class C), p.112; de la Villa, Ending 4, p.37)",
            1, "Silman, Part Four (Class C), p.112; de la Villa, Ending 4, p.37"
        ));
    }
end

// Rule 17 - Lucena Position Candidate (White attacker)
// Attacking king on 8th rank, pawn on 7th rank, not a rook pawn.
rule "Lucena Candidate - White attacker"
when
    DerivedFact( type == "ROOK_PAWN_VS_ROOK", side == Piece.Color.WHITE )
    Piece( type == Piece.Type.PAWN,  color == Piece.Color.WHITE, square matches "[b-g]7" )
    Piece( type == Piece.Type.KING,  color == Piece.Color.WHITE, square matches ".[8]" )
    not DerivedFact( type == "LUCENA_CANDIDATE" )
then
    insert( new DerivedFact(
        "LUCENA_CANDIDATE", Piece.Color.WHITE,
        "Position matches Lucena setup: attacking king on 8th rank sheltered ahead of pawn on 7th rank. Bridge-building technique wins. (de la Villa, Ending 53, p.125)",
        1, "de la Villa, Ending 53, p.125"
    ));
end

// Rule 17b - Lucena Position Candidate (Black attacker)
rule "Lucena Candidate - Black attacker"
when
    DerivedFact( type == "ROOK_PAWN_VS_ROOK", side == Piece.Color.BLACK )
    Piece( type == Piece.Type.PAWN,  color == Piece.Color.BLACK, square matches "[b-g]2" )
    Piece( type == Piece.Type.KING,  color == Piece.Color.BLACK, square matches ".[1]" )
    not DerivedFact( type == "LUCENA_CANDIDATE" )
then
    insert( new DerivedFact(
        "LUCENA_CANDIDATE", Piece.Color.BLACK,
        "Position matches Lucena setup: attacking king on 1st rank sheltered ahead of pawn on 2nd rank. Bridge-building technique wins. (de la Villa, Ending 53, p.125)",
        1, "de la Villa, Ending 53, p.125"
    ));
end

// Rule 18 - Philidor Defense Candidate (White attacker)
// Defending king on 8th rank (in front of pawn), defending rook on rank 6, pawn not yet on 6th rank.
rule "Philidor Candidate - White attacker"
when
    DerivedFact( type == "ROOK_PAWN_VS_ROOK", side == Piece.Color.WHITE )
    Piece( type == Piece.Type.PAWN,  color == Piece.Color.WHITE, $ps : square, square matches ".[1-5]" )
    Piece( type == Piece.Type.KING,  color == Piece.Color.BLACK, square matches ".[8]" )
    Piece( type == Piece.Type.ROOK,  color == Piece.Color.BLACK, square matches ".[6]" )
    not DerivedFact( type == "PHILIDOR_CANDIDATE" )
then
    insert( new DerivedFact(
        "PHILIDOR_CANDIDATE", Piece.Color.WHITE,
        "Philidor defense is set up: defending king in front of pawn on 8th rank, defending rook on 3rd rank (6th absolute). (de la Villa, Ending 52, p.124)",
        1, "de la Villa, Ending 52, p.124"
    ));
end

// Rule 18b - Philidor Defense Candidate (Black attacker)
rule "Philidor Candidate - Black attacker"
when
    DerivedFact( type == "ROOK_PAWN_VS_ROOK", side == Piece.Color.BLACK )
    Piece( type == Piece.Type.PAWN,  color == Piece.Color.BLACK, $ps : square, square matches ".[4-8]" )
    Piece( type == Piece.Type.KING,  color == Piece.Color.WHITE, square matches ".[1]" )
    Piece( type == Piece.Type.ROOK,  color == Piece.Color.WHITE, square matches ".[3]" )
    not DerivedFact( type == "PHILIDOR_CANDIDATE" )
then
    insert( new DerivedFact(
        "PHILIDOR_CANDIDATE", Piece.Color.BLACK,
        "Philidor defense is set up: defending king in front of pawn on 1st rank, defending rook on 6th rank (3rd absolute). (de la Villa, Ending 52, p.124)",
        1, "de la Villa, Ending 52, p.124"
    ));
end

// Rule 19 - Knight on the Edge
rule "Knight on the Edge"
when
    DerivedFact( type == "ROOK_VS_KNIGHT" )
    $kn : Piece( type == Piece.Type.KNIGHT, $knColor : color, $knSq : square,
                 square.substring(0, 1) in ("a", "h") || square.substring(1) in ("1", "8") )
    not DerivedFact( type == "KNIGHT_ON_EDGE" )
then
    insert( new DerivedFact(
        "KNIGHT_ON_EDGE", $knColor,
        "The defending knight is on the edge/corner (" + $knSq + ") — it controls fewer squares and can be cut off and trapped. (de la Villa, Ending 8, p.41; Ending 9, p.42)",
        1, "de la Villa, Ending 8, p.41; Ending 9, p.42"
    ));
end

// Rule 20 - Pawn on 6th Rank (White pawn on rank 6, or Black pawn on rank 3)
rule "Pawn on 6th Rank - White"
when
    DerivedFact( type == "KING_PAWN_ENDGAME" )
    exists Piece( type == Piece.Type.PAWN, color == Piece.Color.WHITE, square matches ".[6]" )
    not DerivedFact( type == "PAWN_ON_SIXTH_RANK", side == Piece.Color.WHITE )
then
    insert( new DerivedFact(
        "PAWN_ON_SIXTH_RANK", Piece.Color.WHITE,
        "Attacking pawn has reached the 6th rank — the critical threshold where opposition and key squares become immediately decisive. (de la Villa, Ending 2, p.29)",
        1, "de la Villa, Ending 2, p.29"
    ));
end

rule "Pawn on 6th Rank - Black"
when
    DerivedFact( type == "KING_PAWN_ENDGAME" )
    exists Piece( type == Piece.Type.PAWN, color == Piece.Color.BLACK, square matches ".[3]" )
    not DerivedFact( type == "PAWN_ON_SIXTH_RANK", side == Piece.Color.BLACK )
then
    insert( new DerivedFact(
        "PAWN_ON_SIXTH_RANK", Piece.Color.BLACK,
        "Attacking pawn has reached the 6th rank — the critical threshold where opposition and key squares become immediately decisive. (de la Villa, Ending 2, p.29)",
        1, "de la Villa, Ending 2, p.29"
    ));
end

// Rule 21 - Attacking King Leads the Pawn (one rank ahead, same file)
rule "King Leads Pawn - White"
when
    DerivedFact( type == "KING_PAWN_ENDGAME" )
    $pawn : Piece( type == Piece.Type.PAWN,  color == Piece.Color.WHITE, $ps : square )
    Piece( type == Piece.Type.KING, color == Piece.Color.WHITE, $ks : square,
           $ks.codePointAt(0) == $ps.codePointAt(0),
           $ks.codePointAt(1) - $ps.codePointAt(1) == 1 )
    not DerivedFact( type == "KING_LEADS_PAWN", side == Piece.Color.WHITE )
then
    insert( new DerivedFact(
        "KING_LEADS_PAWN", Piece.Color.WHITE,
        "Attacking king is directly in front of its pawn — the canonical winning configuration. (Silman, Part Three (Class D), p.61)",
        1, "Silman, Part Three (Class D), p.61"
    ));
end

rule "King Leads Pawn - Black"
when
    DerivedFact( type == "KING_PAWN_ENDGAME" )
    $pawn : Piece( type == Piece.Type.PAWN,  color == Piece.Color.BLACK, $ps : square )
    Piece( type == Piece.Type.KING, color == Piece.Color.BLACK, $ks : square,
           $ks.codePointAt(0) == $ps.codePointAt(0),
           $ps.codePointAt(1) - $ks.codePointAt(1) == 1 )
    not DerivedFact( type == "KING_LEADS_PAWN", side == Piece.Color.BLACK )
then
    insert( new DerivedFact(
        "KING_LEADS_PAWN", Piece.Color.BLACK,
        "Attacking king is directly in front of its pawn — the canonical winning configuration. (Silman, Part Three (Class D), p.61)",
        1, "Silman, Part Three (Class D), p.61"
    ));
end

// Rule 22 - Zugzwang Defender (Trebuchet)
// Defender is to move, holds direct opposition, pawn is advanced, no key square occupied yet.
rule "Zugzwang Defender - White attacker"
when
    DerivedFact( type == "KING_PAWN_ENDGAME" )
    DerivedFact( type == "DIRECT_OPPOSITION" )
    Position( sideToMove == Piece.Color.BLACK )
    Piece( type == Piece.Type.PAWN, color == Piece.Color.WHITE, square matches ".[5-7]" )
    not DerivedFact( type == "KEY_SQUARE_OCCUPIED" )
    not DerivedFact( type == "ZUGZWANG_DEFENDER" )
then
    insert( new DerivedFact(
        "ZUGZWANG_DEFENDER", Piece.Color.WHITE,
        "The defending side is in zugzwang (Trebuchet): any king move must concede the direct opposition. (Silman, Part Four (Class C), p.97: 'Trebuchet: whoever moves, loses')",
        1, "Silman, Part Four (Class C), p.97-100"
    ));
end

rule "Zugzwang Defender - Black attacker"
when
    DerivedFact( type == "KING_PAWN_ENDGAME" )
    DerivedFact( type == "DIRECT_OPPOSITION" )
    Position( sideToMove == Piece.Color.WHITE )
    Piece( type == Piece.Type.PAWN, color == Piece.Color.BLACK, square matches ".[2-4]" )
    not DerivedFact( type == "KEY_SQUARE_OCCUPIED" )
    not DerivedFact( type == "ZUGZWANG_DEFENDER" )
then
    insert( new DerivedFact(
        "ZUGZWANG_DEFENDER", Piece.Color.BLACK,
        "The defending side is in zugzwang (Trebuchet): any king move must concede the direct opposition. (Silman, Part Four (Class C), p.97: 'Trebuchet: whoever moves, loses')",
        1, "Silman, Part Four (Class C), p.97-100"
    ));
end

// Rule 23 - Rook Pawn Edge Detection
rule "Rook Pawn Edge - White"
when
    DerivedFact( type == "ENDGAME_DETECTED" )
    exists Piece( type == Piece.Type.PAWN, color == Piece.Color.WHITE, square matches "[ah][1-8]" )
    not DerivedFact( type == "ROOK_PAWN_EDGE", side == Piece.Color.WHITE )
then
    insert( new DerivedFact(
        "ROOK_PAWN_EDGE", Piece.Color.WHITE,
        "A rook pawn (edge pawn) is on the board — corner drawing resources and wrong-color bishop draws are possible.",
        1, "de la Villa, Ending 4, p.37; Silman, Part Two (Class E), p.45"
    ));
end

rule "Rook Pawn Edge - Black"
when
    DerivedFact( type == "ENDGAME_DETECTED" )
    exists Piece( type == Piece.Type.PAWN, color == Piece.Color.BLACK, square matches "[ah][1-8]" )
    not DerivedFact( type == "ROOK_PAWN_EDGE", side == Piece.Color.BLACK )
then
    insert( new DerivedFact(
        "ROOK_PAWN_EDGE", Piece.Color.BLACK,
        "A rook pawn (edge pawn) is on the board — corner drawing resources and wrong-color bishop draws are possible.",
        1, "de la Villa, Ending 4, p.37; Silman, Part Two (Class E), p.45"
    ));
end
