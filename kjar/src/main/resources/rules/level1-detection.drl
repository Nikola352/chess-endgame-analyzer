package rules;

import com.github.nikola352.chess_endgame_analyzer.model.models.Piece;
import com.github.nikola352.chess_endgame_analyzer.model.models.Position;
import com.github.nikola352.chess_endgame_analyzer.model.models.DerivedFact;
import com.github.nikola352.chess_endgame_analyzer.model.models.KeySquare;

// Rule 12 - Direct Opposition
// Kings face each other with exactly one square between them on the same file or rank.
// The side NOT to move holds the opposition.
rule "Direct Opposition"
when
    $pos : Position( $stm : sideToMove )
    DerivedFact( type == "KING_PAWN_ENDGAME" )
    Piece( type == Piece.Type.KING, color == Piece.Color.WHITE, $wk : square )
    Piece( type == Piece.Type.KING, color == Piece.Color.BLACK, $bk : square,
           ( $bk.codePointAt(0) == $wk.codePointAt(0) && Math.abs($bk.codePointAt(1) - $wk.codePointAt(1)) == 2 )
        || ( $bk.codePointAt(1) == $wk.codePointAt(1) && Math.abs($bk.codePointAt(0) - $wk.codePointAt(0)) == 2 ) )
    not DerivedFact( type == "DIRECT_OPPOSITION" )
then
    Piece.Color holder = "WHITE".equals($stm) ? Piece.Color.BLACK : Piece.Color.WHITE;
    insert( new DerivedFact(
        "DIRECT_OPPOSITION", holder,
        "Kings are in direct opposition. The side to move (" + $stm + ") must step aside, conceding ground.",
        1, "de la Villa, Ending 2, p.29; Silman, Part Two (Class E), p.42"
    ));
end

// Rule 13 - Distant Opposition
// Both kings on the same file or rank separated by 3 or 5 squares (diff of 4 or 6).
rule "Distant Opposition"
when
    DerivedFact( type == "KING_PAWN_ENDGAME" )
    Piece( type == Piece.Type.KING, color == Piece.Color.WHITE, $wk : square )
    Piece( type == Piece.Type.KING, color == Piece.Color.BLACK, $bk : square,
           ( $bk.codePointAt(0) == $wk.codePointAt(0) && ( Math.abs($bk.codePointAt(1) - $wk.codePointAt(1)) == 4 || Math.abs($bk.codePointAt(1) - $wk.codePointAt(1)) == 6 ) )
        || ( $bk.codePointAt(1) == $wk.codePointAt(1) && ( Math.abs($bk.codePointAt(0) - $wk.codePointAt(0)) == 4 || Math.abs($bk.codePointAt(0) - $wk.codePointAt(0)) == 6 ) ) )
    not DerivedFact( type == "DISTANT_OPPOSITION" )
then
    insert( new DerivedFact(
        "DISTANT_OPPOSITION", null,
        "Kings are in distant opposition — the side not to move holds it and can potentially convert to direct opposition.",
        1, "de la Villa, Ending 3, p.35; Silman, Part Two (Class E), p.44"
    ));
end

// Rule 14 - Rule of the Square: White pawn promotes freely
// Defending king is outside the promotion square when it is white's turn to move.
rule "Rule of Square - White pawn, white to move"
when
    DerivedFact( type == "KING_PAWN_ENDGAME" )
    Position( sideToMove == Piece.Color.WHITE )
    $p : Piece( type == Piece.Type.PAWN, color == Piece.Color.WHITE, $ps : square )
    Piece( type == Piece.Type.KING, color == Piece.Color.BLACK, $bk : square,
           Math.max( Math.abs($bk.codePointAt(0) - ($ps.codePointAt(0) - 97 + 97)), Math.abs($bk.codePointAt(1) - 56) )
               > (56 - $ps.codePointAt(1)) )
    not DerivedFact( type == "PAWN_PROMOTES_FREELY", side == Piece.Color.WHITE )
then
    insert( new DerivedFact(
        "PAWN_PROMOTES_FREELY", Piece.Color.WHITE,
        "Defending king is outside the pawn's promotion square — the pawn will promote without being caught. (de la Villa, Ending 1, p.27)",
        1, "de la Villa, Ending 1, p.27; Silman, Part Four (Class C), p.106"
    ));
end

// Rule 14b - Rule of the Square: White pawn promotes freely (black to move)
// Defending king moves first: it gets N king moves before the pawn's Nth push (promotion).
// King can capture the just-promoted queen if distance <= N+1 (be adjacent when queen lands).
// So pawn promotes freely only when distance > N+1.
rule "Rule of Square - White pawn, black to move"
when
    DerivedFact( type == "KING_PAWN_ENDGAME" )
    Position( sideToMove == Piece.Color.BLACK )
    $p : Piece( type == Piece.Type.PAWN, color == Piece.Color.WHITE, $ps : square )
    Piece( type == Piece.Type.KING, color == Piece.Color.BLACK, $bk : square,
           Math.max( Math.abs($bk.codePointAt(0) - $ps.codePointAt(0)), Math.abs($bk.codePointAt(1) - 56) )
               > (56 - $ps.codePointAt(1) + 1) )
    not DerivedFact( type == "PAWN_PROMOTES_FREELY", side == Piece.Color.WHITE )
then
    insert( new DerivedFact(
        "PAWN_PROMOTES_FREELY", Piece.Color.WHITE,
        "Defending king is outside the pawn's promotion square (pawn moves first) — the pawn will promote without being caught. (de la Villa, Ending 1, p.27)",
        1, "de la Villa, Ending 1, p.27; Silman, Part Four (Class C), p.106"
    ));
end

// Rule 14c - Rule of the Square: Black pawn promotes freely (black to move)
rule "Rule of Square - Black pawn, black to move"
when
    DerivedFact( type == "KING_PAWN_ENDGAME" )
    Position( sideToMove == Piece.Color.BLACK )
    $p : Piece( type == Piece.Type.PAWN, color == Piece.Color.BLACK, $ps : square )
    Piece( type == Piece.Type.KING, color == Piece.Color.WHITE, $wk : square,
           Math.max( Math.abs($wk.codePointAt(0) - $ps.codePointAt(0)), Math.abs($wk.codePointAt(1) - 49) )
               > ($ps.codePointAt(1) - 49) )
    not DerivedFact( type == "PAWN_PROMOTES_FREELY", side == Piece.Color.BLACK )
then
    insert( new DerivedFact(
        "PAWN_PROMOTES_FREELY", Piece.Color.BLACK,
        "Defending king is outside the pawn's promotion square — the pawn will promote without being caught. (de la Villa, Ending 1, p.27)",
        1, "de la Villa, Ending 1, p.27; Silman, Part Four (Class C), p.106"
    ));
end

// Rule 14d - Rule of the Square: Black pawn promotes freely (white to move)
rule "Rule of Square - Black pawn, white to move"
when
    DerivedFact( type == "KING_PAWN_ENDGAME" )
    Position( sideToMove == Piece.Color.WHITE )
    $p : Piece( type == Piece.Type.PAWN, color == Piece.Color.BLACK, $ps : square )
    Piece( type == Piece.Type.KING, color == Piece.Color.WHITE, $wk : square,
           Math.max( Math.abs($wk.codePointAt(0) - $ps.codePointAt(0)), Math.abs($wk.codePointAt(1) - 49) )
               > ($ps.codePointAt(1) - 49 + 1) )
    not DerivedFact( type == "PAWN_PROMOTES_FREELY", side == Piece.Color.BLACK )
then
    insert( new DerivedFact(
        "PAWN_PROMOTES_FREELY", Piece.Color.BLACK,
        "Defending king is outside the pawn's promotion square (pawn moves first) — the pawn will promote without being caught. (de la Villa, Ending 1, p.27)",
        1, "de la Villa, Ending 1, p.27; Silman, Part Four (Class C), p.106"
    ));
end

// Rules 14e-14h - King In Square: defending king CAN catch the pawn (draw).
// These are the complements of Rules 14-14d: fire when the condition is <=, not >.

// KING_IN_SQUARE: defending king can catch the pawn AND the attacking king is too far to escort it.
// The second Piece pattern guards that the attacking king is also outside the promotion square
// (Chebyshev distance > moves_to_queen), so it cannot shield the pawn from the defending king.
// If the attacking king is within the square it can interfere; key-square and opposition rules cover that.

rule "King In Square - White pawn, white to move"
when
    DerivedFact( type == "KING_PAWN_ENDGAME" )
    Position( sideToMove == Piece.Color.WHITE )
    $p : Piece( type == Piece.Type.PAWN, color == Piece.Color.WHITE, $ps : square )
    Piece( type == Piece.Type.KING, color == Piece.Color.BLACK, $bk : square,
           Math.max( Math.abs($bk.codePointAt(0) - $ps.codePointAt(0)), Math.abs($bk.codePointAt(1) - 56) )
               <= (56 - $ps.codePointAt(1)) )
    Piece( type == Piece.Type.KING, color == Piece.Color.WHITE, $wk : square,
           Math.max( Math.abs($wk.codePointAt(0) - $ps.codePointAt(0)), Math.abs($wk.codePointAt(1) - 56) )
               > (56 - $ps.codePointAt(1)) )
    not DerivedFact( type == "KING_IN_SQUARE" )
then
    insert( new DerivedFact(
        "KING_IN_SQUARE", Piece.Color.BLACK,
        "Defending king is within the pawn's promotion square and the attacking king cannot assist — the king intercepts the pawn before it queens. (de la Villa, Ending 1, p.27)",
        1, "de la Villa, Ending 1, p.27"
    ));
end

rule "King In Square - White pawn, black to move"
when
    DerivedFact( type == "KING_PAWN_ENDGAME" )
    Position( sideToMove == Piece.Color.BLACK )
    $p : Piece( type == Piece.Type.PAWN, color == Piece.Color.WHITE, $ps : square )
    Piece( type == Piece.Type.KING, color == Piece.Color.BLACK, $bk : square,
           Math.max( Math.abs($bk.codePointAt(0) - $ps.codePointAt(0)), Math.abs($bk.codePointAt(1) - 56) )
               <= (56 - $ps.codePointAt(1) + 1) )
    Piece( type == Piece.Type.KING, color == Piece.Color.WHITE, $wk : square,
           Math.max( Math.abs($wk.codePointAt(0) - $ps.codePointAt(0)), Math.abs($wk.codePointAt(1) - 56) )
               > (56 - $ps.codePointAt(1)) )
    not DerivedFact( type == "KING_IN_SQUARE" )
then
